# ariaops-mcp OAuth e2e config. The issuer URL is what tokens fetched from the
# host carry in `iss` (Keycloak derives it from the request host); the JWKS URL
# is the in-network address the MCP container uses to fetch signing keys.
ARIAOPS_TRANSPORT=http
ARIAOPS_PORT=8080
ARIAOPS_LOG_LEVEL=INFO
ARIAOPS_HTTP_AUTH_MODE=oauth
ARIAOPS_HTTP_OAUTH_PROVIDER=keycloak
ARIAOPS_HTTP_OAUTH_ISSUER_URL=http://localhost:8081/realms/ariaops
ARIAOPS_HTTP_OAUTH_RESOURCE_SERVER_URL=http://localhost:8090/
ARIAOPS_HTTP_OAUTH_JWKS_URL=http://keycloak:8080/realms/ariaops/protocol/openid-connect/certs
ARIAOPS_HTTP_OAUTH_JWT_ALGORITHMS=RS256
ARIAOPS_HTTP_OAUTH_AUDIENCE=ariaops-mcp
# Two fake instances so role-based access is observable; no real Aria Ops is
# contacted by the tests (list_instances and access-denied paths only).
ARIAOPS_INSTANCES=[{"id":"se","host":"vrops-se.test.local","username":"u","password":"p","country":"SE"},{"id":"de","host":"vrops-de.test.local","username":"u","password":"p","country":"DE"}]
# Podman injects the host's proxy vars into containers; neutralize them so the
# JWKS fetch to http://keycloak:8080 is direct.
http_proxy=
https_proxy=
HTTP_PROXY=
HTTPS_PROXY=
no_proxy=keycloak,localhost,127.0.0.1
NO_PROXY=keycloak,localhost,127.0.0.1
