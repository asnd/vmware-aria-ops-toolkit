# LiteLLM Configuration
# Default: remote APIs via litellm (port 4000)
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-your-key-here
LITELLM_MASTER_KEY=sk-your-master-key-here
LITELLM_MODEL=gpt-4o

# Local Models (optional):
# Uncomment to use local embedding service (port 4001)
# LITELLM_BASE_URL=http://litellm-local:4001
# LITELLM_EMBEDDING_MODEL=local-embedding

# LanceDB
LANCEDB_PATH=./data/lancedb

# Scraper Configuration
# Authentication is DISABLED by default (public articles only).
# Set SCRAPER_USE_AUTH=true and provide credentials to access restricted articles.
# Note: Authenticated scraping may have legal implications — use at your own risk.
# NOTE: playwright-based auth requires: pip install -e ".[playwright]"
SCRAPER_USE_AUTH=false
BROADCOM_USERNAME=your-email@example.com
BROADCOM_PASSWORD=your-password
SCRAPER_DELAY_SECONDS=3.0
SCRAPER_MAX_ARTICLES=100
SCRAPER_OUTPUT_DIR=./data/raw

# Web server (Chainlit UI)
SERVER_HOST=0.0.0.0
SERVER_PORT=7860

# Reranker
# Reranking is heuristic-only in the base image; local-model deployments can swap in a
# stronger cross-encoder behind LiteLLM without changing the app configuration.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# Retrieval
RETRIEVAL_SIMILARITY_TOP_K=10
RETRIEVAL_HYBRID_ALPHA=0.7

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Transport: "stdio" (local MCP clients) or "http" (remote, e.g. AI Ops Agent)
MCP_TRANSPORT=stdio
MCP_PORT=8080
MCP_LOG_LEVEL=INFO

# ─── MCP OAuth2 / Keycloak ────────────────────────────────────────────────────
# Enable to require bearer-token auth on the HTTP transport.
# When enabled, all MCP tool calls must present a valid JWT.
MCP_OAUTH_ENABLED=false

# Keycloak issuer URL (the realm URL)
# Example: https://keycloak.example.com/realms/entrag
MCP_OAUTH_ISSUER_URL=https://keycloak.example.com/realms/entrag

# Protected resource identifier (this server's URL)
MCP_OAUTH_RESOURCE_SERVER_URL=http://localhost:8080

# JWKS endpoint for public key retrieval (asymmetric validation)
# Example: https://keycloak.example.com/realms/entrag/protocol/openid-connect/certs
MCP_OAUTH_JWKS_URL=https://keycloak.example.com/realms/entrag/protocol/openid-connect/certs

# JWT algorithms (RS256 for Keycloak RSA keys; comma-separated)
MCP_OAUTH_JWT_ALGORITHMS=RS256

# Required scopes (comma-separated). Empty = no scope enforcement.
# Example: entrag:read,entrag:write
MCP_OAUTH_REQUIRED_SCOPES=

# Audience claim (optional, defaults to resource_server_url if unset)
MCP_OAUTH_AUDIENCE=

# Clock skew tolerance in seconds
MCP_OAUTH_LEEWAY_SECONDS=30

# JWKS key cache TTL in seconds
MCP_OAUTH_JWKS_CACHE_TTL=300

# Static JWT secret (alternative to JWKS, for HMAC algorithms only — NOT recommended for production)
# MCP_OAUTH_JWT_KEY=
