# ─── AriaOps MCP Server ────────────────────────────────────────────────────────
ARIAOPS_HOST=vrops.example.com
ARIAOPS_USERNAME=admin
ARIAOPS_PASSWORD=changeme
ARIAOPS_AUTH_SOURCE=local
ARIAOPS_VERIFY_SSL=true
ARIAOPS_TRANSPORT=stdio
ARIAOPS_PORT=8080
# Optional: require OAuth 2.x bearer tokens on the HTTP transport.
# When enabled, /health stays open but the MCP endpoint requires a valid JWT
# in the Authorization: Bearer <token> header.
# ARIAOPS_HTTP_OAUTH_ENABLED=false
# ARIAOPS_HTTP_OAUTH_PROVIDER=generic
# ARIAOPS_HTTP_OAUTH_ISSUER_URL=https://issuer.example.com
# ARIAOPS_HTTP_OAUTH_RESOURCE_SERVER_URL=https://mcp.example.com
#
# Verification material — set EITHER JWT_KEY or JWKS_URL, not both:
#   JWT_KEY  → static HMAC secret (HS*) or PEM public key (RS*/ES*/PS*)
#     - HS256/384/512: random secret >=32 bytes; generate with `python -c
#       "import secrets; print(secrets.token_urlsafe(32))"`
#     - RS*/ES*/PS*: single-line PEM (escape newlines as \n)
#   JWKS_URL → fetched from the IdP and cached. Required for IdPs with key rotation.
# ARIAOPS_HTTP_OAUTH_JWT_KEY=replace-me-with-a-32-byte-random-secret
# ARIAOPS_HTTP_OAUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
#
# Keycloak example — provider=keycloak derives JWKS from the realm URL and
# defaults JWT algorithms to RS256 when JWT_KEY/JWKS_URL are not set explicitly.
# ARIAOPS_HTTP_OAUTH_PROVIDER=keycloak
# ARIAOPS_HTTP_OAUTH_ISSUER_URL=https://kc.example.com/realms/myrealm
# # Keycloak puts the OIDC clientId in `aud` only if you add an Audience mapper —
# # set this to your client ID (or whatever your mapper emits):
# ARIAOPS_HTTP_OAUTH_AUDIENCE=mcp-client
#
# ARIAOPS_HTTP_OAUTH_JWT_ALGORITHMS=HS256
# Optional: override audience claim. Defaults to RESOURCE_SERVER_URL.
# ARIAOPS_HTTP_OAUTH_AUDIENCE=https://mcp.example.com
# Comma-separated list of scopes that the token must carry.
# ARIAOPS_HTTP_OAUTH_REQUIRED_SCOPES=mcp:read
# Clock-skew tolerance for exp/nbf/iat (seconds). Default: 30.
# ARIAOPS_HTTP_OAUTH_LEEWAY_SECONDS=30
# JWKS cache TTL in seconds (only when JWKS_URL is set). Default: 300.
# ARIAOPS_HTTP_OAUTH_JWKS_CACHE_TTL=300
#
# ─── LDAP / Active Directory authentication (HTTP transport) ──────────────────
# Alternative to OAuth. MCP clients send HTTP Basic credentials; the server
# binds to LDAPS to verify them and reads `memberOf` to derive the SAME
# role/country/instance claims that OAuth uses (see role-based access below).
# Select it with ARIAOPS_HTTP_AUTH_MODE=ldap (mutually exclusive with OAuth).
# ARIAOPS_HTTP_AUTH_MODE=ldap
# ARIAOPS_LDAP_SERVER_URI=ldaps://dc1.corp.example.com:636
# AD UPN bind (no service account):  {username}@corp.example.com
# Generic LDAP bind:                 uid={username},ou=people,dc=corp,dc=com
# ARIAOPS_LDAP_USER_DN_TEMPLATE={username}@corp.example.com
# ARIAOPS_LDAP_USER_SEARCH_BASE=dc=corp,dc=example,dc=com
# Map AD group (CN or full DN) → principal role. An "ops" group grants all
# instances; a "country" group pins one instance via its country/instance.
# When omitted, every authenticated user gets ARIAOPS_DEFAULT_ROLE (ops).
# ARIAOPS_LDAP_GROUP_ROLE_MAP={"vrops-ops":{"role":"ops"},"vrops-se":{"role":"country","country":"SE"}}
# ARIAOPS_LDAP_CA_CERT_FILE=/etc/ssl/certs/ca-bundle.crt
# ARIAOPS_LDAP_VERIFY_TLS=true
# ARIAOPS_LDAP_CACHE_TTL=300
# ARIAOPS_LDAP_BIND_TIMEOUT=10
ARIAOPS_LOG_LEVEL=INFO
# Uncomment to enable write/mutating operations (disabled by default)
# ARIAOPS_ENABLE_WRITE_OPERATIONS=false

# ─── Multiple Aria Operations instances (optional) ────────────────────────────
# By default the single ARIAOPS_HOST/USERNAME/PASSWORD above is used. To serve
# several Aria Operations instances from one MCP server, set ARIAOPS_INSTANCES to
# a JSON array instead (the single-host vars above may then be omitted). Each
# entry needs a unique `id`; `country` is used to pin "country" role users.
# ARIAOPS_INSTANCES=[{"id":"us","host":"us.vrops.example.com","username":"svc","password":"secret","country":"US"},{"id":"de","host":"de.vrops.example.com","username":"svc","password":"secret","country":"DE"}]
#
# Role-based access:
#   • ops     → may target ANY instance (pass the tool's `instance` argument).
#   • country → pinned to the ONE instance matching their country/instance claim.
# On the HTTP transport, role/country/instance are read from the JWT claims
# below; on stdio they fall back to the ARIAOPS_DEFAULT_* values.
# ARIAOPS_ROLE_CLAIM=ariaops_role
# ARIAOPS_COUNTRY_CLAIM=ariaops_country
# ARIAOPS_INSTANCE_CLAIM=ariaops_instance
# ARIAOPS_OPS_ROLE=ops
# ARIAOPS_COUNTRY_ROLE=country
# ARIAOPS_DEFAULT_ROLE=ops
# ARIAOPS_DEFAULT_COUNTRY=US
# ARIAOPS_DEFAULT_INSTANCE=us

# ─── Agent Skills ─────────────────────────────────────────────────────────────
# Path to directory containing SKILL.md files. Leave empty to disable skills.
# ARIAOPS_SKILLS_DIR=/path/to/skills

# ─── Test-UI: LLM Gateway ─────────────────────────────────────────────────────
# OpenAI-compatible LLM gateway URL (e.g. LiteLLM proxy)
LITELLM_BASE_URL=https://litellm.example.com
# JWT token for authenticating to the gateway (obtain via Azure SSO or paste manually)
LITELLM_TOKEN=

# ─── Test-UI: Azure AD SSO (optional overrides) ───────────────────────────────
# Required only if you want to use the "Get Token via Azure SSO" button
# AZURE_TENANT_ID=your-azure-tenant-id
# AZURE_CLIENT_ID=your-azure-client-id
