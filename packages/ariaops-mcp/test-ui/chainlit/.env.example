# ─── Chainlit auth test harness ───────────────────────────────────────────────
# Copy to .env and fill in. See CHAINLIT_AUTH.md for the full walkthrough.

# Where the AriaOps MCP server is listening (its HTTP transport, port 8080).
ARIAOPS_MCP_URL=http://localhost:8080/

# Required by Chainlit to sign the auth/session cookie.
# Generate with:  chainlit create-secret
CHAINLIT_AUTH_SECRET=replace-me

# ─── Password login → MCP LDAP mode ───────────────────────────────────────────
# No extra config here: defining @cl.password_auth_callback (in app.py) is what
# enables the username/password form. The MCP server must be started with
# ARIAOPS_HTTP_AUTH_MODE=ldap so it can verify the forwarded Basic credentials.

# ─── OAuth login → MCP OAuth mode ─────────────────────────────────────────────
# Use Chainlit's built-in Keycloak provider (matches the MCP server's Keycloak
# support). The MCP server must run with OAuth enabled against the SAME realm.
# OAUTH_KEYCLOAK_CLIENT_ID=chainlit-ui
# OAUTH_KEYCLOAK_CLIENT_SECRET=replace-me
# OAUTH_KEYCLOAK_REALM=myrealm
# OAUTH_KEYCLOAK_BASE_URL=https://kc.example.com
# OAUTH_KEYCLOAK_NAME=Keycloak
# Required when Chainlit runs behind a reverse proxy:
# CHAINLIT_URL=https://chat.example.com

# ─── Optional LLM gateway (OpenAI-compatible) ─────────────────────────────────
# When all three are set, the app runs a tool-using chat agent. When unset, the
# app still tests auth: type "<tool_name> {json-args}" to call a tool directly.
# LITELLM_BASE_URL=https://litellm.example.com
# LITELLM_TOKEN=
# LLM_MODEL=
