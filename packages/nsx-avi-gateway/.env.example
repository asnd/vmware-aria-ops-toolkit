# NSX-T/AVI API Gateway Configuration
# Copy this file to .env and configure with your values

# Application
GATEWAY_APP_NAME="NSX-T/AVI API Gateway"
GATEWAY_DEBUG=false
GATEWAY_API_VERSION=v1

# Configuration Paths
GATEWAY_SITES_CONFIG_PATH=config/sites.yml
GATEWAY_OPERATIONS_ALLOWLIST_PATH=config/operations_allowlist.yml

# JWT Authentication (required)
# Generate a strong secret key for HS256 with: openssl rand -hex 32
GATEWAY_JWT_SECRET_KEY=""
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_ACCESS_TOKEN_EXPIRE_MINUTES=60

# For RS256 (asymmetric) - optional, leave empty to use HS256
# GATEWAY_JWT_PRIVATE_KEY_PATH=
# GATEWAY_JWT_PUBLIC_KEY_PATH=

# Local authentication user password hashes (required)
# Generate each hash with Python:
# python -c "from getpass import getpass; from app.auth.oauth2 import get_password_hash; print(get_password_hash(getpass()))"
GATEWAY_ADMIN_PASSWORD_HASH=""
GATEWAY_OPERATOR_PASSWORD_HASH=""
GATEWAY_READONLY_PASSWORD_HASH=""

# Job Tracking
GATEWAY_JOB_RETENTION_MINUTES=1440  # 24 hours
GATEWAY_JOB_CLEANUP_INTERVAL_SECONDS=300  # 5 minutes
GATEWAY_MAX_CONCURRENT_JOBS=50

# API Timeouts (seconds)
GATEWAY_API_CONNECTION_TIMEOUT=30
GATEWAY_API_OPERATION_TIMEOUT=300  # 5 minutes for long operations
GATEWAY_API_MAX_RETRIES=3

# Idempotency
GATEWAY_IDEMPOTENCY_CACHE_TTL_SECONDS=86400  # 24 hours

# Logging
GATEWAY_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
GATEWAY_LOG_FORMAT=json  # json or text
GATEWAY_AUDIT_LOG_PATH=logs/audit.jsonl

# Server (for uvicorn)
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_WORKERS=1  # Increase for production

# CORS (optional - for web UI from different origin)
# GATEWAY_CORS_ORIGINS=http://localhost:3000,https://gateway.example.com
